# Environment variables for secrets sync daemon

# Azure Key Vault authentication
AZURE_ACCESS_TOKEN=your_azure_access_token_here

# Vaultwarden authentication
VAULTWARDEN_TOKEN=your_vaultwarden_api_token_here

# HashiCorp Vault authentication
VAULT_TOKEN=your_hashicorp_vault_token_here

# Custom API authentication
API_KEY=your_custom_api_key_here

# Database path (optional, defaults to sync.db)
DATABASE_PATH=/app/data/sync.db

# Config file path (optional, defaults to config.yaml)
CONFIG_PATH=/etc/sync/config.yaml

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Logging format (json or text)
LOG_FORMAT=json
